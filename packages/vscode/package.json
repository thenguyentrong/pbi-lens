{
  "name": "pbi-lens-vscode",
  "displayName": "PBI Lens (Power BI Viewer + MCP)",
  "description": "View Power BI reports inside VS Code — and let your AI agent see them too",
  "version": "0.2.0",
  "publisher": "duckduck-beps",
  "author": "duckduck_beps",
  "private": true,
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Visualization",
    "Data Science"
  ],
  "keywords": [
    "power bi",
    "powerbi",
    "dashboard",
    "report",
    "dax",
    "mcp",
    "ai",
    "claude",
    "copilot",
    "screenshot"
  ],
  "icon": "icon.png",
  "license": "MIT",
  "galleryBanner": {
    "color": "#1e2230",
    "theme": "dark"
  },
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pbiLens.login",
        "title": "PBI Lens: Sign in to Power BI"
      },
      {
        "command": "pbiLens.openReport",
        "title": "PBI Lens: Open Report"
      },
      {
        "command": "pbiLens.capturePage",
        "title": "PBI Lens: Capture Page for Claude (PNG)"
      },
      {
        "command": "pbiLens.refreshReports",
        "title": "PBI Lens: Refresh Reports",
        "icon": "$(refresh)"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "pbiLensReports",
          "name": "Power BI Reports",
          "icon": "$(graph)"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "pbiLensReports",
        "contents": "Browse your Power BI workspaces, reports and pages here.\n[Sign in to Power BI](command:pbiLens.login)\nAfter signing in, click refresh if the list stays empty."
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "pbiLens.refreshReports",
          "when": "view == pbiLensReports",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "PBI Lens",
      "properties": {
        "pbiLens.workspace": {
          "type": "string",
          "default": "",
          "description": "Default Power BI workspace (id or name)"
        },
        "pbiLens.report": {
          "type": "string",
          "default": "",
          "description": "Default report (id or name)"
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@pbi-lens/core": "0.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.6.0"
  }
}
