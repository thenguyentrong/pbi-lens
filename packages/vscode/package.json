{
  "name": "pbi-lens-vscode",
  "displayName": "PBI Lens",
  "description": "View Power BI reports inside VS Code — and let your AI agent see them too",
  "version": "0.1.0",
  "publisher": "vinh",
  "private": true,
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Visualization"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pbiLens.login",
        "title": "PBI Lens: Sign in to Power BI"
      },
      {
        "command": "pbiLens.openReport",
        "title": "PBI Lens: Open Report"
      },
      {
        "command": "pbiLens.capturePage",
        "title": "PBI Lens: Capture Page for Claude (PNG)"
      }
    ],
    "configuration": {
      "title": "PBI Lens",
      "properties": {
        "pbiLens.workspace": {
          "type": "string",
          "default": "",
          "description": "Default Power BI workspace (id or name)"
        },
        "pbiLens.report": {
          "type": "string",
          "default": "",
          "description": "Default report (id or name)"
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@pbi-lens/core": "0.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.6.0"
  }
}
